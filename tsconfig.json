{
  "compilerOptions": {
    "composite": false, 
   
    "outDir": "./dist",
    "declaration": false, 
    "skipLibCheck": true,
    "module": "esnext",
"moduleResolution": "bundler",
"esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "types": ["node", "vite/client"],
    "jsx": "react-jsx"
  },
  "include": [
    "src/**/*",
    "api/**/*"
  ],
  "exclude": ["node_modules", "dist", "**/*.spec.ts"]
}