{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "types": ["node", "vite/client"],
    "jsx": "react-jsx"
  },
  "include": [
    "vite.config.ts",
    "src/**/*",
    "api/**/*",
    "backend/**/*"
  ]
}